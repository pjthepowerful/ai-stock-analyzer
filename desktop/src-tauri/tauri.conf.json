{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Paula",
    "version": "1.0.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "Paula — Intraday Trading",
        "width": 920,
        "height": 720,
        "minWidth": 680,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "window": { "all": true },
      "process": { "all": true }
    },
    "bundle": {
      "active": true,
      "identifier": "com.paula.trading",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": "all"
    },
    "security": {
      "csp": null
    }
  }
}
