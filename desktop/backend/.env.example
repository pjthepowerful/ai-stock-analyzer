# Paula backend environment variables.
#
# SETUP:  copy this file to ".env" in the same directory, then fill in real
# values.  The real .env is gitignored and never committed.
#
#   cp .env.example .env
#
# Once .env exists you no longer need to `export` anything — just run:
#   source venv/bin/activate && python server.py

# ── Alpaca (paper trading) ──────────────────────────────────────────────────
ALPACA_KEY_ID=your_alpaca_key_id
ALPACA_SECRET=your_alpaca_secret

# ── Groq (AI responses) ─────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key

# ── Polygon (price data fallback) ───────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key

# ── Resend (password-reset emails) — OPTIONAL ───────────────────────────────
# Without RESEND_API_KEY, reset links print to the server console (dev mode).
RESEND_API_KEY=
# Defaults to "Paula <onboarding@resend.dev>" which can only deliver to your
# own Resend account email until you verify a sending domain.
RESET_FROM_EMAIL=
# Base URL used to build reset links in emails.
FRONTEND_URL=https://paula-seven.vercel.app
