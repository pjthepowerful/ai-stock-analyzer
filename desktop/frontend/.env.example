# Frontend config — copy this file to ".env" and fill in your backend URL.
#
# VITE_API_URL is the public URL of your Paula backend.
# Set this when hosting so the deployed frontend knows where to reach the backend.
#
# Examples:
#   Local dev (you don't need to set it — it auto-uses http://127.0.0.1:3141)
#   ngrok:      VITE_API_URL=https://your-current-ngrok-url.ngrok-free.dev
#   Railway:    VITE_API_URL=https://paula-backend.up.railway.app
#
# IMPORTANT: with the free ngrok plan the URL changes every restart, so you
# must update this value (and rebuild/redeploy the frontend) each time.

VITE_API_URL=
